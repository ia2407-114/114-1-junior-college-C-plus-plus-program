介面檔:
#include <iostream>
using namespace std;

class Pet
{
private:
    string name;
    int age;

public:
    Pet(string n, int a);

    void show();

    ~Pet();
};

實作檔:
#include "pet.h"

Pet::Pet(string n, int a)
{
    name = n;
    age = a;
    cout << "寵物 " << name << " 已建立！" << endl;
}

void Pet::show()
{
    cout << "姓名: " << name << "，年齡: " << age << endl;
}

Pet::~Pet()
{
    cout << "寵物 " << name << " 再見！" << endl;
}


