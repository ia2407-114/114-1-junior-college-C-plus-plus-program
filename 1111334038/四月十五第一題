date實作檔:

#include <iostream>
#include <iomanip>
#include <stdexcept>
#include "date.h"
using namespace std;

Date::Date(int y, int m, int d)
{
    setDate(y, m, d);
}

void Date::setDate(int y, int m, int d)
{
    year = y;
    month = m;
    day = d;
}

bool Date::isValid()
{
    if (month < 1 || month > 12)
        return false;

    if (day < 1 || day > 31)
        return false;

    if ((month == 4 || month == 6 || month == 9 || month == 11) && day > 30)
        return false;

    if (month == 2 && day > 28)
        return false;

    return true;
}

void Date::showAD()
{
    cout << "西元日期: " << year << "/" << month << "/" << day << endl;
}

void Date::showROC()
{
    cout << "民國日期: " << year - 1911 << "/" << month << "/" << day << endl;
}

