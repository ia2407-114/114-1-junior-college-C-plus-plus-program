pet實作檔:

#include <iostream>
#include "pet.h"
using namespace std;

Pet::Pet(string n, string c, Date b, Date a)
    : name(n), category(c), birthday(b), adoptDate(a)
{
}

Pet::~Pet()
{
    cout << name << " says: Bye Bye~~" << endl;
}

void Pet::check_birth()
{
    cout << name << " 的生日檢查: ";
    if (birthday.isValid())
        birthday.showAD();
    else
        cout << "生日不合法" << endl;
}

void Pet::check_adopt()
{
    cout << name << " 的領養日檢查: ";
    if (adoptDate.isValid())
        adoptDate.showAD();
    else
        cout << "領養日不合法" << endl;
}

void Pet::print_all_data()
{
    cout << "名稱: " << name << endl;
    cout << "品種: " << category << endl;

    cout << "生日: ";
    birthday.showROC();

    cout << "領養日: ";
    adoptDate.showROC();

    cout << "------------------------" << endl;
}

