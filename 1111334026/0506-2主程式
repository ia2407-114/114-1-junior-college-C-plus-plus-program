#include <iostream>
#include "Matrix.h"

using namespace std;

int main() {
    int row, column;
    
    cout << "測試一元運算子多載：\n";
    cout << "輸入矩陣A的列數(row):";
    cin >> row;
    cout << "輸入矩陣A的行數(column):";
    cin >> column;
    
    Matrix a(row, column);
    
    cout << "輸入一" << row << 'x' << column << "矩陣A" << endl; 
    for (int i = 0; i < row; i++) {
        for (int j = 0; j < column; j++) {
            cout << "A[" << i << "][" << j << "]=";
            cin >> a.element[i][j];
        }
    }
    
    cout << "=======================================" << endl;
    // 測試開平方根 (前置運算子)
    !a; 
    
    cout << "=======================================" << endl;
    // 測試取2次方 (後置運算子)
    a++; 
  
    return 0;
}
