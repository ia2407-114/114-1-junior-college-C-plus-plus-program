#include "shape.h"
void shape::area()
{
    cout << "圖形面積:" << shape_area << endl;
}
void rectangle::data_input()
{
    cout << "輸入長方形的長與寬:";
    cin >> length >> width;
    shape_area = length * width;
}
void cube::data_input()
{
    rectangle::data_input();
    cout << "輸入長方形的高:";
    cin >> height;
}
void cube::display()
{
    cout << "長方體體積是" << length * width * height << endl;
}
