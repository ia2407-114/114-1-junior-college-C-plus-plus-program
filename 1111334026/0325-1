#include <iostream>
#include <string> 
using namespace std;

class myPet
{
public:

    string getName() const
    {
        return PetName;
    }
    int getAge() const
    {
        return PetAge;
    }
    void setName(string name)
    {
        if (name.length() > 2 && name.length() < 5)
            PetName = name;
    }
    void setAge(int Age)
    {
        if (Age > 20)
            PetAge = Age;
    }
    void www() const {
        cout << "寵物姓名: " << getName() << endl;
        cout << "寵物年齡: " << getAge() << " 歲" << endl;
    }
private:
    string PetName = "John";
    int PetAge = 6;
};


int main()
{
    myPet dog;

    string name;
    int age;
    cout << "請輸入寵物姓名" << endl;
    getline(cin, name);
    dog.setName(name);

    cout << "請輸入寵物年齡:" << endl;
    cin >> age;
    dog.setAge(age);

    dog.www();
  
  

    //myPet.getName;

}



