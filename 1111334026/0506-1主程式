#include <iostream>
#include "Matrix.h"

using namespace std;

int main() {
    int row, column;
    
    cout << "重新定義「!」前置運算子的多載，求A矩陣元素的平方根(!A)：\n";
    cout << "輸入矩陣A的列數(row):";
    cin >> row;
    cout << "輸入矩陣A的行數(column):";
    cin >> column;
    
    // 建立 Matrix 物件 a
    Matrix a(row, column);
    
    cout << "輸入一" << row << 'x' << column << "矩陣A" << endl; 
    for (int i = 0; i < row; i++) {
        for (int j = 0; j < column; j++) {
            cout << "A[" << i << "][" << j << "]=";
            cin >> a.element[i][j];
        }
    }
    
    cout << "=======================================" << endl;
    
    // 直接呼叫 !a，該運算子會自動將元素開平方根並印出
    !a; 
  
    return 0;
}
