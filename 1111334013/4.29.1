count.cpp
#include <iostream>
using namespace std;

#include "Count.h"

// constructor
Count::Count() : x(0)
{
}

// print function
void Count::print() const
{
	cout << x << endl;
}

// friend function
void setX(Count& c, int val)
{
	c.x = val;
}

main.cpp
#include <iostream>
using namespace std;

#include "Count.h"
#include "printDate.h"

int main()
{
	Count counter;
	printDate pd;

	cout << "初始值: ";
	counter.print();

	setX(counter, 8);

	cout << "使用 friend function 後: ";
	counter.print();

	cout << "使用 friend class 顯示: ";
	pd.showX(counter);

	return 0;
}

printdate.cpp
#include <iostream>
using namespace std;

#include "printDate.h"

// 因為是 friend class，可以直接存取 private x
void printDate::showX(Count& c)
{
	cout << "printDate 顯示 Count.x = " << c.x << endl;
}

count.h
#pragma once
#ifndef COUNT_H
#define COUNT_H

class printDate; // 前置宣告

class Count
{
	friend void setX(Count&, int);
	friend class printDate; // 新增 friend class

public:
	Count();
	void print() const;

private:
	int x;
};

#endif

