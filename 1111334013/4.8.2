#include <iostream>
#include <stdexcept>
#include "Dog.h"

using namespace std;

int main() {
    try {
        Dog d("Lucky", 2020, 5, 1, 2021, 6, 1);

        cout << "預設資料：" << endl;
        d.printInfo();

        cout << "\n請輸入新資料：" << endl;
        d.input();

        cout << "\n結果：" << endl;
        d.printInfo();
