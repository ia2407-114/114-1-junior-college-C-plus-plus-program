#include "Shape.h"

#define PI 3.14159

Cone::Cone(double r, double h)
{
    radius = r;
    height = h;
}

double Cone::Volume()
{
    return PI * radius * radius * height / 3.0;
}

Ball::Ball(double r)
{
    radius = r;
}

double Ball::Volume()
{
    return 4.0 / 3.0 * PI * radius * radius * radius;
}

Cylinder::Cylinder(double r, double h)
{
    radius = r;
    height = h;
}

double Cylinder::Volume()
{
    return PI * radius * radius * height;
}
