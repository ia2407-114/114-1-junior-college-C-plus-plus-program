#include <iostream>
#include "Shape.h"

using namespace std;

int main()
{
    Shape* a1;

    Cone cone(3, 5);
    Ball ball(3);
    Cylinder cylinder(3, 5);

    a1 = &cone;
    cout << "Cone Volume = "<< a1->Volume() << endl;

    a1 = &ball;
    cout << "Ball Volume = "<< a1->Volume() << endl;

    a1 = &cylinder;
    cout << "Cylinder Volume = "<< a1->Volume() << endl;

    return 0;
}
