Shape.h
#ifndef SHAPE_H
#define SHAPE_H

class Shape
{
public:
    virtual double Volume() = 0; 
    virtual ~Shape() {}
};

class Cone : public Shape
{
private:
    double radius;
    double height;

public:
    Cone(double r, double h);
    double Volume();
};

class Ball : public Shape
{
private:
    double radius;

public:
    Ball(double r);
    double Volume();
};

class Cylinder : public Shape
{
private:
    double radius;
    double height;

public:
    Cylinder(double r, double h);
    double Volume();
};

#endif
