#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
struct student {
    int id;
    char name[20];
    int computer, math;
    double avg;
};
int main(void)
{
    FILE* cfPtr;
    if ((cfPtr = fopen("students.dat", "wb+")) == NULL) {
        puts("File could not be opened.");
        return 1;
    }
    struct student client;
    printf("Enter id (1-100, 0 to end): ");
    scanf("%d", &client.id);
    while (client.id != 0) {
        printf("Enter name, computer, math: ");
        scanf("%19s%d%d",
            client.name,
            &client.computer,
            &client.math);
        client.avg = (client.computer + client.math) / 2.0;
        fseek(cfPtr, (client.id - 1) * sizeof(struct student),SEEK_SET);
        fwrite(&client, sizeof(struct student), 1, cfPtr);
        printf("Enter id (1-100, 0 to end): ");
        scanf("%d", &client.id);
    }
    fclose(cfPtr);
    if ((cfPtr = fopen("students.dat", "rb")) == NULL) {
        puts("File could not be opened.");
        return 1;
    }
    printf("\nID   Name   Computer   Math   Avg\n");
    printf("--------------------------------------\n");
    while (fread(&client, sizeof(struct student), 1, cfPtr) == 1) {
        if (client.id != 0) {
            printf("%d   %s   %d   %d   %.2f\n",
                client.id,
                client.name,
                client.computer,
                client.math,
                client.avg);
        }
    }
    fclose(cfPtr);
    return 0;
}借放
