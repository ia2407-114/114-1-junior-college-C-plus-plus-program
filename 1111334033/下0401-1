#include <iostream>
#include <string>
using namespace std;
class PET
{
public:
    PET(string name, int age)
    {
        petName = name;
        petAge = age;
    }
    void displayMessage() const
    {
        cout << "我的寵物名字是 " << petName
            << "，年齡是 " << petAge << " 歲" << endl;
    }
    ~PET()
    {
        cout << "再見了，" << petName << "！" << endl;
    }
private:
    string petName;
    int petAge;
};
int main()
{
    PET myPet1("dog", 3);
    PET myPet2("cat", 5);

    myPet1.displayMessage();
    myPet2.displayMessage();

    return 0;
}
