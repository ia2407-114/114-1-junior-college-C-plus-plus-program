#include <iostream>
#include "BombPlane.h"

using namespace std;

// 輸入資料
void inputBombPlane(BombPlane& bomb)
{
    cout << "名稱:";
    cin >> bomb.name;

    cout << "編號:";
    cin >> bomb.id;

    cout << "駕駛員人數:";
    cin >> bomb.pilot;

    cout << "煤油量(公升):";
    cin >> bomb.kerosene;

    cout << "乘客人數:";
    cin >> bomb.passenger;

    cout << "武器名稱:";
    cin >> bomb.weapon;

    cout << "製造者:";
    cin >> bomb.manufacturer;
}

// 顯示資料
void displayBombPlane(const BombPlane& bomb)
{
    cout << "\n轟炸機資料\n";

    cout << "名稱:" << bomb.name << endl;
    cout << "編號:" << bomb.id << endl;
    cout << "駕駛員人數:" << bomb.pilot << endl;
    cout << "煤油量(公升):" << bomb.kerosene << endl;
    cout << "乘客人數:" << bomb.passenger << endl;
    cout << "武器名稱:" << bomb.weapon << endl;
    cout << "製造者:" << bomb.manufacturer << endl;
}
