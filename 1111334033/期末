main.cpp
#include <iostream>
#include <fstream>
#include "BombPlane.h"

using namespace std;

int main()
{
    BombPlane bomb1;
    BombPlane bomb2;

    cout << "建立轟炸機資料\n";
    inputBombPlane(bomb1);

    // 寫入二進位檔
    fstream file("bomb.bin",ios::out | ios::binary);

    file.write(reinterpret_cast<char*>(&bomb1),sizeof(BombPlane));

    file.close();

    // 讀取二進位檔
    file.open("bomb.bin",ios::in | ios::binary);

    file.read(reinterpret_cast<char*>(&bomb2),sizeof(BombPlane));

    file.close();

    displayBombPlane(bomb2);

    return 0;
}
