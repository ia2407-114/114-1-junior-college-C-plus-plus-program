Animal.cpp
#include "Animal.h"
#include <iomanip>

Animal::Animal()
{
    name = "";
    age = 0;
    height = 0;
}

Animal::Animal(string n, int a, int h)
{
    name = n;
    age = a;
    height = h;
}

void Animal::input()
{
    cin >> name >> age >> height;
}

void Animal::writeToFile(ofstream& file)
{
    file << left
        << setw(15) << name
        << setw(10) << age
        << setw(10) << height
        << endl;
}

void Animal::display()
{
    cout << left
        << setw(15) << name
        << setw(10) << age
        << setw(10) << height
        << endl;
}
