#include <iostream>
#include <fstream>
#include <iomanip>
#include "Animal.h"
using namespace std;

int main()
{
    ofstream writefile;

    writefile.open("animal.txt", ios::out);

    if (writefile.fail())
    {
        cout << "animal.txt檔案無法開啟!\n";
        return 1;
    }

    Animal animal[3];

    // 檔案標題
    writefile << left
        << setw(15) << "動物"
        << setw(10) << "年齡"
        << setw(10) << "身高"
        << endl;

    for (int i = 0; i < 3; i++)
    {
        cout << "輸入第" << i + 1
            << "種動物名稱、年齡及身高(以空白鍵區隔)：";

        animal[i].input();

        animal[i].writeToFile(writefile);

        if (writefile.fail())
        {
            cout << "寫入失敗!\n";
            break;
        }
    }

    writefile.close();

    cout << "\n=== 動物資料表 ===\n";

    cout << left
        << setw(15) << "動物"
        << setw(10) << "年齡"
        << setw(10) << "身高"
        << endl;

    for (int i = 0; i < 3; i++)
    {
        animal[i].display();
    }

    return 0;
}
