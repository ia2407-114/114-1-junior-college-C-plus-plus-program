/*題目3. 承上題根據fig11_11.c的檔案內容，利用已建立的空白隨機存取檔，存入3筆學生資料，學生的結構(struct)為:
struct student {
 int id;
    char name[20];
    int computer, math;
    double avg;
};*/
#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
struct student {
    int id;
    char name[20];
    int computer, math;
    double avg;
};
int main(void)
{
    FILE* cfPtr;
    /* -------- Step 1: 建立空白隨機存取檔 -------- */
    if ((cfPtr = fopen("students.txt", "wb")) == NULL) {
        puts("File could not be opened.");
        return 1;
    }
    struct student blank = { 0, "", 0, 0, 0.0 };
    for (int i = 0; i < 100; i++) {
        fwrite(&blank, sizeof(struct student), 1, cfPtr);
    }
    fclose(cfPtr);
    /* -------- Step 2: 開啟檔案並寫入 3 筆資料 -------- */
    if ((cfPtr = fopen("students.txt", "rb+")) == NULL) {
        puts("File could not be opened.");
        return 1;
    }
    struct student stu;
    printf("Enter 3 students (id name computer math):\n");
    for (int i = 0; i < 3; i++) {
        scanf("%d %19s %d %d", &stu.id, stu.name, &stu.computer, &stu.math);
        stu.avg = (stu.computer + stu.math) / 2.0;
        fseek(cfPtr, (stu.id - 1) * sizeof(struct student), SEEK_SET);
        fwrite(&stu, sizeof(struct student), 1, cfPtr);
    }
    fclose(cfPtr);
    puts("File created and 3 records written successfully.");
    return 0;
}
