另建立一個類別printDate設定為friend class，再使用此類別(物件)的函數印出物件Count的x內容。*/
main.cpp
#include <iostream>
#include "Count.h"
using namespace std;

int main() {
    Count counter;  
    PrintDate pd;   

    cout << "1. 初始狀態 (使用成員函式): ";
    counter.print();

    setX(counter, 8);
    cout << "2. 呼叫 setX(8) 後 (使用成員函式): ";
    counter.print();

    pd.showCountX(counter);

    return 0;
}
