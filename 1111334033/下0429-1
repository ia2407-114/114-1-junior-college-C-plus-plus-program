Count.cpp
#include <iostream>
#include "Count.h"
using namespace std;
Count::Count()
    : x(0)
{
}

void Count::print() const {
    cout << x << endl;
}
void setX(Count& c, int val) {
    c.x = val;
}

void PrintDate::showCountX(const Count& c) {
    cout << "[PrintDate] 透過友員類別存取到的 x 為: " << c.x << endl;
}
