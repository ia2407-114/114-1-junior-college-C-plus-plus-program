Shape.h
#ifndef SHAPE_H
#define SHAPE_H

#include <iostream>
#include <string>
using namespace std;

class Shape
{
private:
    string name;
    double shape_area;

public:
    Shape(string = "shape", double = 0);

    void setName(string);
    string getName() const;

    void setArea(double);
    double getArea() const;

    void area() const;
};

#endif
---------
Shape.cpp
#include "Shape.h"

Shape::Shape(string n, double a)
{
    name = n;
    shape_area = a;
}

void Shape::setName(string n)
{
    name = n;
}

string Shape::getName() const
{
    return name;
}

void Shape::setArea(double a)
{
    shape_area = a;
}

double Shape::getArea() const
{
    return shape_area;
}

void Shape::area() const
{
    cout << "體積為: " << shape_area << endl;
}
