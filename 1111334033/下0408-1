/*題目1. 建立一個可以讓使用者透過鍵盤輸入西年、月、日，分別印出西元與民國日期，但程式碼需達成以下條件:
1.請使用類別定義，定義部分請用”抽象方法”
(抽象方法就是介面與實作分離)
2. 日期部分請透過建構子設定與設定預設值
(預設值為1990年1月1號)
3. 必須判斷內容是否正確，例如2017/03/32為錯誤的日期*/
Sourse.cpp
#include <iostream>
#include "Date.h"
using namespace std;

int main()
{
    int y, m, d;

    cout << "請輸入西元 年 月 日：";
    cin >> y >> m >> d;

    Date t1(y, m, d);

    cout << "\n你輸入的日期是：\n";
    cout << "西元：";
    t1.printAD();

    cout << "\n";
    t1.printROC();
    cout << endl;

    return 0;
}
