Teacher.h
#ifndef TEACHER_H
#define TEACHER_H

#include <iostream>
#include <string>
using namespace std;

class teacher
{
protected:
    int teacher_id;
    string teacher_name;

    int course_id;
    string course_name;
    int course_credit;

public:
    teacher(int id, string name);

    void data_input();

    string getTeacherName();
    int getCourseID();
    string getCourseName();
    int getCourseCredit();
};

#endif
-----------
Teacher.cpp
#include "Teacher.h"

teacher::teacher(int id, string name)
{
    teacher_id = id;
    teacher_name = name;
}

void teacher::data_input()
{
    cout << "請輸入課程編號: ";
    cin >> course_id;

    cin.ignore();

    cout << "請輸入課程名稱: ";
    getline(cin, course_name);

    cout << "請輸入課程學分: ";
    cin >> course_credit;
}

string teacher::getTeacherName()
{
    return teacher_name;
}

int teacher::getCourseID()
{
    return course_id;
}

string teacher::getCourseName()
{
    return course_name;
}

int teacher::getCourseCredit()
{
    return course_credit;
}
