Classroom.cpp
#include "Classroom.h"

classroom::classroom(int tid, string tname,int sid, string sname): teacher(tid, tname), student(sid, sname)
{
}

void classroom::show()
{
    cout << "\n===== 課堂資料 =====" << endl;

    cout << "課程編號: " << getCourseID() << endl;
    cout << "課程名稱: " << getCourseName() << endl;
    cout << "課程學分: " << getCourseCredit() << endl;

    cout << "教師姓名: " << getTeacherName() << endl;
    cout << "學生姓名: " << getStudentName() << endl;
}
