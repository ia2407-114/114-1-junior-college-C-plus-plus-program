#include "Cinema.h"

void MovieSystem::inputMovies()
{
    Cinema movie;

    ofstream file("movie.bin", ios::binary);
        if (!file)
        {
            cout << "movie.bin檔案無法開啟!\n";
            return;
        }

    cout << "請輸入5筆電影資料\n";

    for (int i = 0; i < 5; i++)
    {
        cout << "\n第 " << i + 1 << " 筆資料\n";

        cout << "電影名稱:";
        cin >> movie.name;

        cout << "上映日期:";
        cin >> movie.date;

        cout << "上映廳處:";
        cin >> movie.place;

        cout << "票價:";
        cin >> movie.price;

        file.write((char*)&movie, sizeof(Cinema));
    }
    file.close();
}

void MovieSystem::displayTitles()
{
    ifstream file("movie.bin", ios::binary);
        if (!file)
        {
            cout << "movie.bin檔案無法開啟!\n";
            return;
        }
    Cinema movie;
    int no = 1;

    cout << "\n電影資訊:\n";

    while (file.read((char*)&movie, sizeof(Cinema)))
    {
        cout << no << ".電影名稱:" << movie.name << endl;
        no++;
    }

    file.close();
}

void MovieSystem::displayMovie(int no)
{
    ifstream file("movie.bin", ios::binary);
        if (!file)
        {
            cout << "movie.bin檔案無法開啟!\n";
            return;
        }

    Cinema movie;

    file.seekg(sizeof(Cinema) * (no - 1), ios::beg);

    file.read((char*)&movie, sizeof(Cinema));

    if (!file.fail())
    {
        cout << "\n電影名稱:" << movie.name << endl;
        cout << "上映日期:" << movie.date << endl;
        cout << "上映廳處:" << movie.place << endl;
        cout << "票價:" << movie.price << endl;
    }
    else
    {
        cout << "查無電影資料!\n";
    }

    file.close();
}
