#include <iostream>
#include "Pet.h"
using namespace std;
// ================= Date =================
Date::Date(int y, int m, int d) {
    setDate(y, m, d);
}
void Date::setDate(int y, int m, int d) {
    year = y;
    month = m;
    day = d;
}
int Date::getYear() const
{
    return year;
}
int Date::getMonth() const
{
    return month;
}
int Date::getDay() const
{
    return day;
}
void Date::printDate() const
{
    cout << year << "/" << month << "/" << day;
}
// ================= Dog =================
Dog::Dog(string n,Date b,Date a):bd(b),ad(a) {
    name = n;
    int age = 2026 - bd.getYear();
    if (age < 0 || age > 20)
    {
        cout << "\n狗的年齡不合理\n";
        
    }

    if (ad.getYear() < bd.getYear())
    {
        cout << "領養日不能早於生日，已修正為生日\n";
        ad = bd;
    }
}
void Dog::printInfo() const
{
    cout << "\n=== 狗狗資料 ===\n";
    cout << "名字：" << name << endl;

   cout << "生日：";
    bd.printDate();
    cout << endl;

    cout << "領養日：";
    ad.printDate();
    cout << endl;

    cout << "年齡：" << 2026 - bd.getYear() << " 歲" << endl;
}
