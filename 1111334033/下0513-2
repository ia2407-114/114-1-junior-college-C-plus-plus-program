aircraft.h
#ifndef AIRCRAFT_H
#define AIRCRAFT_H
#include <iostream>
#include <string>
using namespace std;

class aircraft
{
private:
    string name;     
    int id;          
    float wingspan;  
    float ceiling;   

public:
    aircraft();

    ~aircraft();

    void display();
};

#endif
--------------
aircraft.cpp
#include "aircraft.h"
aircraft::aircraft()
{
    cout << "執行 aircraft 建構元\n";

    cout << "請輸入飛行器名稱:";
    cin >> name;

    cout << "請輸入編號:";
    cin >> id;

    cout << "請輸入翼展(公尺):";
    cin >> wingspan;

    cout << "請輸入升限(公尺):";
    cin >> ceiling;
}

aircraft::~aircraft()
{
    cout << "執行 aircraft 解構元\n";
}

void aircraft::display()
{
    cout << "\n===== 飛行器資料 =====\n";
    cout << "名稱:" << name << endl;
    cout << "編號:" << id << endl;
    cout << "翼展:" << wingspan << " 公尺" << endl;
    cout << "升限:" << ceiling << " 公尺" << endl;
}
