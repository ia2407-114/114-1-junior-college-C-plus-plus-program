/*題目1. 利用範例1.cpp的類別中，建立一個前序一元運算子多載，!a可以將矩陣a的元素開"平方根"之後印出，
矩陣元素的形態要使用float或double。請分成以介面檔與實作檔的方式撰寫
題目2. 承上題，在Matrix中再加入一個"後序"一元運算子多載，a++可以計算出矩陣a的每個元素的"2次方"後印出，
矩陣元素的形態要使用float或double。請分成以介面檔與實作檔的方式撰寫
*/
main.cpp
#include <iostream>
#include "Matrix.h"
using namespace std;

int main()
{
    int i, j, row, column;

    cout << "測試 !（開根號）與 ++（平方）運算子\n";
    cout << "輸入列數(row): ";
    cin >> row;
    cout << "輸入行數(column): ";
    cin >> column;

    Matrix a(row, column), b(row, column), c(row, column);

    cout << "輸入矩陣 A：" << endl;
    for (i = 0; i < row; i++)
        for (j = 0; j < column; j++)
        {
            cout << "A[" << i << "][" << j << "] = ";
            cin >> a.element[i][j];
        }

    b = !a;  
   

    cout << "\n!A（平方根）：\n";
    for (i = 0; i < row; i++)
    {
        for (j = 0; j < column; j++)
            cout << b.element[i][j] << "\t";
        cout << endl;
    }

    c = a++;
    cout << "\na++（平方）：\n";
    for (i = 0; i < row; i++)
    {
        for (j = 0; j < column; j++)
            cout << c.element[i][j] << "\t";
        cout << endl;
    }

    return 0;
}
