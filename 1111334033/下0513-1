main.cpp
#include <iostream>
#include "Time.h"

using namespace std;

int main()
{
    Time time1(8, 24, 36);
    Time time2;

    cout << "time1 is " << time1 << endl;
    cout << "time2 is " << time2 << endl;

    cout << "\nTesting postfix ++" << endl;
    cout << "time1++ is " << time1++ << endl;
    cout << "time1 is " << time1 << endl;

    cout << "\nTesting prefix ++" << endl;
    cout << "++time1 is " << ++time1 << endl;
    cout << "time1 is " << time1 << endl;

    cout << "\nTesting += operator" << endl;
    cout << "time1 += 30 is " << (time1 += 30) << endl;

    return 0;
}
