#pragma once
//函數多載:多個函數的名稱相同，功能不相同
/*區別方式:
(1)參數的數量
(2)參數的型態
(3)順序的型態
*/

int volume(int k)//正方體積
{
  return k * k * k;
}

double volume(int value1, int value2)//圓柱體積
{
    double pi = 3.14159;
    return value1 * value1 *pi* value2;
}

int volume(int value1, int value2, int value3)//長方體體積
{
    return value1 * value2 * value3;
}


