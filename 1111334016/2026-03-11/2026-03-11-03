#include <iostream>
#include <iomanip> // 用於格式化輸出

using namespace std;

// 函式原型宣告：使用 & 符號表示傳址呼叫 (Call by Reference)
double power(int& base, int& exp);
double fact(int& n);

int main() {
    int x, i;

    // 使用 C++ 標準輸入流 cin
    cout << "Enter x (底數) = ";
    cin >> x;
    cout << "Enter i (階乘/次方數) = ";
    cin >> i;

    // 輸出結果，使用 cout 替代 printf
    cout << "--------------------------" << endl;
    cout << "冪次結果 (" << x << "^" << i << "): " << power(x, i) << endl;
    cout << "階乘結果 (" << i << "!): " << fact(i) << endl;
    cout << "--------------------------" << endl;

    return 0;
}

// 【冪次函數】計算 base 的 exp 次方
// 參數使用 int & 進行傳址，雖然此處未修改原值，但符合題目要求
double power(int& base, int& exp) {
    double xpow = 1.0;

    // 如果次方為 0，結果為 1
    for (int k = 1; k <= exp; k++) {
        xpow *= base;
    }
    return xpow;
}

// 【階乘函數】計算 n!
double fact(int& n) {
    double level = 1.0;

    // 處理 0! = 1 的定義，迴圈從 n 開始遞減
    if (n == 0) return 1.0;

    for (int j = n; j >= 1; j--) {
        level *= j;
    }
    return level; // 修正：原程式碼漏掉回傳值
}
