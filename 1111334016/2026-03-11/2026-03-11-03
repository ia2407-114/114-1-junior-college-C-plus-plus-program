/*題目3 請用C++改寫以下程式碼，並且使用傳位址(call by reference)的方式傳遞與回傳參數:
階乘函數:請輸入一個X值，用for迴圈算出並印出X的階乘X!
階乘 : X = 5階乘 = 1 * 2 * 3 * 4 * 5 = 120，0階乘 = 1(定義)
冪次函數(power function) : 輸入整數a和n，求出a ^ n值 :*/
#include <iostream>
#include <iomanip> // 用於格式化輸出

    using namespace std;/*接下來如果我用到一些標準函式庫的東西，請直接去 std（Standard）這個『命名空間』 裡面找。」
                        ，避免兩個程式設計師都取了同名的函式，找不到正確的函數 */
                        //如果沒有的話，要std::cout << "Enter x (底數) = ";

    // 函式原型宣告：使用 & 符號表示傳址呼叫 (Call by Reference)

    double power(int& base, int& exp);//使用傳位址 (call by reference) 的方式傳遞與回傳參數「傳址呼叫」，不加&資料簿會跟著改變
    double fact(int& n);

    int main()
    {
        int x, i;

        
        cout << "Enter x (底數) = ";//printf
        cin >> x;//scanf
        cout << "Enter i (階乘/次方數) = ";
        cin >> i;

       
       
        cout << "次方結果 (" << x << "^" << i << "): " << power(x, i) << endl;//end1等於\n
        cout << "階層結果 (" << i << "!): " << fact(i) << endl;
       

        return 0;
    }

    // 【冪次函數】計算 base 的 exp 次方
    // 參數使用 int & 進行傳址，雖然此處未修改原值，但符合題目要求
    double power(int& base, int& exp) {//副程式 1
        //次方
        double xpow = 1.0;

        // 如果次方為 0，結果為 1
        for (int k = 1; k <= exp; k++) {// k:計算要乘幾次
            xpow *= base;
        }
        return xpow;
    }// xpow=xpow * x ?5 * 5 * 5 * 5 * 5 * 5= 3125
    /*i=5,y=5; 
    k=1;1<=5;xpow=1*5=5
    k=1;2<=5;xpow=5=5*5=25;*/







    // 【階乘函數】計算 n!
    double fact(int& n) {//副程式 2
        //階層
        double level = 1.0;

        // 處理 0! = 1 的定義，迴圈從 n 開始遞減
        if (n == 0) return 1.0;

        for (int j = n; j >= 1; j--) {
            level *= j;
        }
        return level; 
    }// level=level * j  ?5 * 4 * 3 * 2 * 1
    //j=5;5>=1;5--
