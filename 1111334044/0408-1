#include <iostream>
#include "time.h"

using namespace std;

int main() {
    int y, m, d;
    cout << "請輸入西元年 月 日 (空格隔開): ";
    if (!(cin >> y >> m >> d)) {
        cout << "輸入格式錯誤。" << endl;
        return 1;
    }

    DateConverter userDate(y, m, d);
    userDate.printAD();
    userDate.printROC();

    return 0;
}
