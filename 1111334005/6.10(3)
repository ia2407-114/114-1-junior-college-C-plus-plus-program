main.cpp
#include "Animal.h"

int main()
{
    AnimalFile af;

    // 輸入資料並存成二進位檔
    af.inputAnimals();

    // 計算平均值
    af.calculateAverage();

    // 顯示所有資料
    af.displayFile();

    return 0;
}
























