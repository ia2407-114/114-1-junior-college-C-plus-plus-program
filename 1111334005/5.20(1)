cube.h
#ifndef CUBE_H
#define CUBE_H

#include "rectangle.h"

class Cube : public Rectangle {
private:
    double height;

public:
    Cube();

    void data_input();
};

#endif
________________________________________________________________
cube.cpp
#include <iostream>
#include "cube.h"

using namespace std;

Cube::Cube() {
    height = 0;
}

void Cube::data_input() {

    // 呼叫 Rectangle 的 data_input()
    Rectangle::data_input();

    cout << "請輸入長方體的高: ";
    cin >> height;

    // 計算體積
    shape_area = length * width * height;
}
