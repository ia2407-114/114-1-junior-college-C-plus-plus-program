#include <iostream>
#include "rectangle.h"

using namespace std;

Rectangle::Rectangle() {
    length = 0;
    width = 0;
}

void Rectangle::data_input() {
    cout << "請輸入長方體的長: ";
    cin >> length;

    cout << "請輸入長方體的寬: ";
