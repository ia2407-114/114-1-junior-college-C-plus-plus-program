main.cpp（主程式）
#include "Animal.h"
#include <iomanip>

int main()
{
    // ======================
    // 第一部分：輸入並寫入檔案
    // ======================

    ofstream writeFile("animal.txt");

    if (writeFile.fail())
    {
        cout << "animal.txt檔案無法開啟！" << endl;
        return 1;
    }

    writeFile << left
              << setw(12) << "動物"
              << setw(12) << "年齡"
              << setw(12) << "身高"
              << endl;

    Animal a[3];

    for (int i = 0; i < 3; i++)
    {
        cout << "請輸入第" << i + 1
             << "種動物名稱、年齡、身高：";

        a[i].inputData();
        a[i].writeToFile(writeFile);
    }

    writeFile.close();

    // ======================
    // 第二部分：讀取檔案計算平均
    // ======================

    fstream rwFile;
    rwFile.open("animal.txt",
                ios::in | ios::out | ios::app);

    if (rwFile.fail())
    {
        cout << "animal.txt檔案無法開啟！" << endl;
        return 1;
    }

    ifstream readFile("animal.txt");

    string title;
    getline(readFile, title);

    string name;
    int age, height;

    float totalAge = 0;
    float totalHeight = 0;
    int count = 0;

    while (readFile >> name >> age >> height)
    {
        totalAge += age;
        totalHeight += height;
        count++;
    }

    readFile.close();

    float avgAge = totalAge / count;
    float avgHeight = totalHeight / count;

    rwFile << fixed << setprecision(1);
    rwFile << "\n平均年齡: "
           << avgAge
           << "\t平均身高: "
           << avgHeight
           << endl;

    rwFile.close();

    // ======================
    // 第三部分：讀取整個檔案並顯示
    // ======================

    ifstream showFile("animal.txt");

    if (showFile.fail())
    {
        cout << "檔案讀取失敗！" << endl;
        return 1;
    }

    cout << "\n===== animal.txt內容 =====\n"
         << endl;

    string line;

    while (getline(showFile, line))
    {
        cout << line << endl;
    }

    showFile.close();

    return 0;
}




























