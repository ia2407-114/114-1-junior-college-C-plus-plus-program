題目2: 請結核病修改範例6.cpp、範例7.cpp程式碼，具有格式化輸入與輸出的功能，前半部先透過鍵盤輸入三種動物的年齡與身高，在格式化寫入到檔案中。後半部再次打開、讀取檔案，計算所有動物的平均身高與年齡，並將資料寫回檔案中。
最後，將整個檔案內容讀取出來並列印到螢幕中。請利用介面/實作分離的程式設計方式完成。
____________________________________________________________________________
Animal.h（介面檔）
#ifndef ANIMAL_H
#define ANIMAL_H

#include <iostream>
#include <fstream>
#include <string>
using namespace std;

class Animal
{
private:
    string name;
    int age;
    int height;

public:
    Animal();

    void inputData();
    void writeToFile(ofstream &outFile);

    string getName();
    int getAge();
    int getHeight();
};

#endif
___________________________________________________________________________
Animal.cpp（實作檔）
#include "Animal.h"

Animal::Animal()
{
    name = "";
    age = 0;
    height = 0;
}

void Animal::inputData()
{
    cin >> name >> age >> height;
}

void Animal::writeToFile(ofstream &outFile)
{
    outFile << name << '\t'
            << age << '\t'
            << height << '\n';
}

string Animal::getName()
{
    return name;
}

int Animal::getAge()
{
    return age;
}

int Animal::getHeight()
{
    return height;
}
