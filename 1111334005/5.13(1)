#ifndef TIME_H
#define TIME_H

#include <iostream>
using namespace std;

class Time {
    friend ostream& operator<<(ostream&, const Time&);

public:
    Time(int h = 0, int m = 0, int s = 0);

    void setTime(int, int, int);

    // 前置 ++
    Time& operator++();

    // 後置 ++
    Time operator++(int);

    // += 秒數
    Time& operator+=(unsigned int);

private:
    unsigned int hour;
    unsigned int minute;
    unsigned int second;

    void helpIncrement();
};

#endif

Time.cpp
#include <iostream>
#include <stdexcept>
#include "Time.h"

using namespace std;

// 建構子
Time::Time(int h, int m, int s) {
    setTime(h, m, s);
}

// 設定時間
void Time::setTime(int h, int m, int s) {

    if (h >= 0 && h < 24)
        hour = h;
    else
        throw invalid_argument("Hour must be 0-23");

    if (m >= 0 && m < 60)
        minute = m;
    else
        throw invalid_argument("Minute must be 0-59");

    if (s >= 0 && s < 60)
        second = s;
    else
        throw invalid_argument("Second must be 0-59");
}

// 前置++
Time& Time::operator++() {

    helpIncrement();

    return *this;
}

// 後置++
Time Time::operator++(int) {

    Time temp = *this;

    helpIncrement();

    return temp;
}

// += 秒數
Time& Time::operator+=(unsigned int additionalSeconds) {

    for (unsigned int i = 0; i < additionalSeconds; i++) {
        helpIncrement();
    }

    return *this;
}

// 時間遞增1秒
void Time::helpIncrement() {

    ++second;

    // 秒滿60
    if (second >= 60) {
        second = 0;
        ++minute;
    }

    // 分滿60
    if (minute >= 60) {
        minute = 0;
        ++hour;
    }

    // 時滿24
    if (hour >= 24) {
        hour = 0;
    }
}

// 輸出運算子 <<
ostream& operator<<(ostream& output, const Time& t) {

    output << t.hour << ":"
           << t.minute << ":"
           << t.second;

    return output;
}

main.cpp
#include <iostream>
#include "Time.h"

using namespace std;

int main() {

    Time time1(8, 24, 36);

    cout << "原始時間: " << time1 << endl;

    // 前置++
    cout << "\n測試前置++" << endl;
    cout << "++time1 = " << ++time1 << endl;
    cout << "time1 = " << time1 << endl;

    // 後置++
    cout << "\n測試後置++" << endl;
    cout << "time1++ = " << time1++ << endl;
    cout << "time1 = " << time1 << endl;

    // +=
    cout << "\n測試 += " << endl;
    time1 += 30;

    cout << "time1 += 30 後: " << time1 << endl;

    return 0;
}


































