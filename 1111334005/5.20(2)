main.cpp
#include <iostream>
#include "classroom.h"

using namespace std;

int main() {

    int tid, sid;
    string tname, sname;

    cout << "請輸入教師編號: ";
    cin >> tid;

    cin.ignore();

    cout << "請輸入教師姓名: ";
    getline(cin, tname);

    cout << "請輸入學生編號: ";
    cin >> sid;

    cin.ignore();

    cout << "請輸入學生姓名: ";
    getline(cin, sname);

    Classroom c(tid, tname, sid, sname);

    c.data_input();

    c.show();

    return 0;
}















