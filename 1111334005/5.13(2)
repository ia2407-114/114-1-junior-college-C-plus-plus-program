main.cpp
#include <iostream>
#include "airliner.h"
#include "fightJet.h"

using namespace std;

int main() {

    cout << "===== 客機資料 =====" << endl;

    airliner a1(
        60.3,
        43000,
        "Boeing 777",
        "BR777",
        350,
        8
    );

    a1.printAirliner();

    cout << endl;

    cout << "===== 戰鬥機資料 =====" << endl;

    fightJet f1(
        13.5,
        65000,
        "F-22 Raptor",
        "USAF22",
        6,
        2.25
    );

    f1.printFightJet();

    return 0;
}













