fightJet.h
#ifndef FIGHTJET_H
#define FIGHTJET_H

#include "aircraft.h"

class fightJet : public aircraft {

private:
    int missiles;      // 飛彈數量
    double mach;       // 馬赫速度

public:
    // 建構子
    fightJet(double, int, string, string, int, double);

    // 解構子
    ~fightJet();

    // 印出資料
    void printFightJet();
};

#endif
_________________________________________________________________

fightJet.cpp
#include "fightJet.h"

// 建構子
fightJet::fightJet(double ws, int ce, string n,
                   string i, int m, double ma)
    : aircraft(ws, ce, n, i)
{
    missiles = m;
    mach = ma;

    cout << "fightJet 建構子執行" << endl;
}

// 解構子
fightJet::~fightJet() {

    cout << "fightJet 解構子執行" << endl;
}

// 印出資料
void fightJet::printFightJet() {

    printAircraft();

    cout << "飛彈數量: " << missiles << endl;
    cout << "飛行速度(馬赫): " << mach << endl;
}

