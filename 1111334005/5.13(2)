airliner.h
#ifndef AIRLINER_H
#define AIRLINER_H

#include "aircraft.h"

class airliner : public aircraft {

private:
    int passengers;   // 乘客數量
    int toilets;      // 廁所數量

public:
    // 建構子
    airliner(double, int, string, string, int, int);

    // 解構子
    ~airliner();

    // 印出資料
    void printAirliner();
};

#endif
____________________________________________________________
airliner.cpp
#include "airliner.h"

// 建構子
airliner::airliner(double ws, int ce, string n,
                   string i, int p, int t)
    : aircraft(ws, ce, n, i)
{
    passengers = p;
    toilets = t;

    cout << "airliner 建構子執行" << endl;
}

// 解構子
airliner::~airliner() {

    cout << "airliner 解構子執行" << endl;
}

// 印出資料
void airliner::printAirliner() {

    printAircraft();

    cout << "乘客數量: " << passengers << endl;
    cout << "廁所數量: " << toilets << endl;
}
