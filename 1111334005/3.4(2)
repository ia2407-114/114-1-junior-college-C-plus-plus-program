#include <stdio.h>


struct student {
    int id;
    char name[20];
    int computer, math;
    double avg;
};

int main(void) {
    FILE* cfPtr; 


    if ((cfPtr = fopen("students.dat", "rb")) == NULL) {
        puts("檔案無法開啟。");
    }
    else {
 
        printf("%-6s%-20s%-10s%-10s%-10s\n",
            "ID", "Name", "Computer", "Math", "Average");

 
        while (!feof(cfPtr)) {
            
            struct student std = { 0, "", 0, 0, 0.0 };

            
            int result = fread(&std, sizeof(struct student), 1, cfPtr);

            
            if (result != 0 && std.id != 0) {
                printf("%-6d%-20s%-10d%-10d%-10.2f\n",
                    std.id, std.name, std.computer, std.math, std.avg);
            }
        }

        fclose(cfPtr); 
    }

    return 0;
}
