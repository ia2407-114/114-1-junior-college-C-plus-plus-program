#include <iostream>
#include "pet.h" // 只要引入標頭檔即可使用 Pet 類別

using namespace std;

int main() {
	// 建立兩個物件
	Pet pet1("小黃", 3);
	Pet pet2("阿福", 5);

	// 呼叫函數
	pet1.displayInfo();
	pet2.displayInfo();

	cout << "--- 程式主體執行結束 ---" << endl;

	return 0; // 程式結束後，pet2 與 pet1 會依序自動執行解構元
}

---------------------------------pet.h

#ifndef PET_H
#define PET_H

#include <string>

class Pet {
private:
	std::string name;
	int age;

public:
	// 僅宣告建構元與解構元
	Pet(std::string n, int a);
	~Pet();

	// 僅宣告成員函數
	void displayInfo();
};

#endif#pragma once

---------------------------------pet.cpp

#include <iostream>
#include "pet.h" // 必須包含介面檔

using namespace std;

// 實作建構元
Pet::Pet(string n, int a) {
	name = n;
	age = a;
	cout << "寵物物件 " << name << " 已建立。" << endl;
}

// 實作解構元
Pet::~Pet() {
	cout << "再見了，" << name << "！(解構元已執行)" << endl;
}

// 實作顯示函數
void Pet::displayInfo() {
	cout << "寵物姓名: " << name << ", 年齡: " << age << " 歲" << endl;
}
