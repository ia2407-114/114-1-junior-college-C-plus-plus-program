#include <iostream>
#include <cmath> // 為了使用 M_PI 或計算次方

using namespace std;

// 1. 計算正方體體積：1 個整數 (邊長)
int volume(int s) {
    cout << "正方體體積 (邊長 " << s << "): ";
    return s * s * s;
}

// 2. 計算圓柱體體積：2 個整數 (底半徑 r, 高 h)
// 注意：體積通常有小數，建議回傳 double
double volume(int r, int h) {
    cout << "圓柱體體積 (半徑 " << r << ", 高 " << h <<"):"; 
    return 3.14159 * r * r * h;
}

// 3. 計算長方體體積：3 個整數 (長 l, 寬 w, 高 h)
int volume(int l, int w, int h) {
    cout << "長方體體積 (長 " << l << ", 寬 " << w << ", 高 " << h << "):"; 
    return l * w * h;
}

int main() {
    // 呼叫 1 個參數的版本
    cout << volume(7) << endl;

    // 呼叫 2 個參數的版本
    cout << volume(5, 10) << endl;

    // 呼叫 3 個參數的版本
    cout << volume(5, 6, 7) << endl;

    return 0;
}
