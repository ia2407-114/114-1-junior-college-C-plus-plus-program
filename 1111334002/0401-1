#include <iostream>
#include <string>

using namespace std;

class Pet {
private:
	// 私有資料成員
	string name;
	int age;

public:
	// 建構元：設定寵物的姓名與年齡
	Pet(string n, int a) {
		name = n;
		age = a;
		cout << "寵物物件 " << name << " 已建立。" << endl;
	}

	// 解構元：印出再見訊息
	~Pet() {
		cout << "再見了，" << name << "！(解構元已執行)" << endl;
	}

	// 成員函數：印出資料
	void displayInfo() {
		cout << "寵物姓名: " << name << ", 年齡: " << age << " 歲" << endl;
	}
};

int main() {
	// 建立兩隻寵物物件，透過建構元傳入參數
	Pet pet1("小黃", 3);
	Pet pet2("阿福", 5);

	// 印出寵物資訊
	pet1.displayInfo();
	pet2.displayInfo();

	cout << "--- 程式結束前 ---" << endl;

	return 0;
}
