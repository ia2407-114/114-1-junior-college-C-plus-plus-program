#include <iostream>
#include "Count.h"
#include "PrintDate.h"
using namespace std;

int main() {
    Count counter;
    PrintDate pd;

    cout << "Initial value: ";
    counter.print();

    setX(counter, 8);

    pd.showCountX(counter);

    return 0;
}

count.h

#ifndef COUNT_H
#define COUNT_H

class PrintDate; 

class Count {

    friend class PrintDate;

    friend void setX(Count&, int);

public:
    Count();      
    void print() const; 

private:
    int x; 
};

#endif

count.cpp

#include <iostream>
#include "Count.h"
using namespace std;

Count::Count() : x(0) {
}

void Count::print() const {
    cout << x << endl;
}

void setX(Count& c, int val) {
    c.x = val; 
}

