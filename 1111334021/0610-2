#include "Animal.h"

Animal::Animal()
{
    name = "";
    age = 0;
    height = 0;
}

void Animal::input()
{
    cin >> name >> age >> height;
}

void Animal::writeToFile(ofstream& file)
{
    file << name << '\t'
        << age << '\t'
        << height << '\n';
}

string Animal::getName()
{
    return name;
}

int Animal::getAge()
{
    return age;
}

int Animal::getHeight()
{
    return height;
}
