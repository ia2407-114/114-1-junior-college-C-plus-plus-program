#include <iostream>
#include <fstream>
#include <iomanip>
#include <string>
#include "Animal.h"

using namespace std;

int main()
{
    Animal animal[3];

    //--------------------------------
    // 第一部分：輸入並寫入檔案
    //--------------------------------

    ofstream writefile;

    writefile.open("animal.txt", ios::out);

    if (writefile.fail())
    {
        cout << "animal.txt檔案無法開啟!\n";
        return 1;
    }

    writefile << left
        << setw(15) << "動物"
        << setw(10) << "年齡"
        << setw(10) << "身高"
        << endl;

    for (int i = 0; i < 3; i++)
    {
        cout << "輸入第"
            << i + 1
            << "種動物名稱、年齡及身高(以空白鍵區隔):\n";

        animal[i].input();

        writefile << left
            << setw(15) << animal[i].getName()
            << setw(10) << animal[i].getAge()
            << setw(10) << animal[i].getHeight()
            << endl;
    }

    writefile.close();

    //--------------------------------
    // 第二部分：讀取並計算平均值
    //--------------------------------

    fstream read_writefile;

    read_writefile.open(
        "animal.txt",
        ios::in | ios::out
    );

    if (read_writefile.fail())
    {
        cout << "animal.txt檔案無法開啟!\n";
        return 1;
    }

    string title;

    getline(read_writefile, title);

    string name;
    int age, height;

    float total_age = 0;
    float total_height = 0;

    for (int i = 0; i < 3; i++)
    {
        read_writefile
            >> name
            >> age
            >> height;

        total_age += age;
        total_height += height;
    }

    float avgAge = total_age / 3;
    float avgHeight = total_height / 3;

    cout << fixed << setprecision(1);

    cout << "\n平均年齡:"
        << avgAge
        << "\t平均身高:"
        << avgHeight
        << endl;

    //--------------------------------
    // 寫回檔尾
    //--------------------------------

    read_writefile.clear();

    read_writefile.seekp(0, ios::end);

    read_writefile << endl;

    read_writefile << "平均年齡:"
        << avgAge
        << "\t平均身高:"
        << avgHeight
        << endl;

    read_writefile.close();

    //--------------------------------
    // 第三部分：讀取整個檔案並顯示
    //--------------------------------

    ifstream showfile("animal.txt");

    string line;

    cout << "\n===== animal.txt內容 =====\n";

    while (getline(showfile, line))
    {
        cout << line << endl;
    }

    showfile.close();

    return 0;
}
