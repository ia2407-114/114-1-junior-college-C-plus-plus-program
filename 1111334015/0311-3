#include <stdio.h>

double power(int&, int&);
double fact(int&);

int main()
{
    int x, i;

    printf("Enter x = ");
    scanf_s("%d", &x);

    printf("Enter i = ");
    scanf_s("%d", &i);

    printf("result: %f, %f\n", power(x, i), fact(i));

    return 0;
}

double fact(int& i)
{
    int j;
    double level = 1.0;

    if (i == 0)   // 0! = 1
        return 1;

    for (j = i; j >= 1; j--)
    {
        level *= j;
    }

    return level;
}

double power(int& x, int& y)
{
    double xpow = 1;
    int k;

    for (k = 1; k <= y; k++)
    {
        xpow *= x;
    }

    return xpow;
}
