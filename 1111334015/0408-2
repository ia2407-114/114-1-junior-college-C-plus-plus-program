#include "pet.h"
using namespace std;

int main() {
    // 先給預設值（之後用 input 覆蓋）
    PetDog dog("", 0, 0, 0, 0, 0, 0);

    dog.input();

    if (dog.checkValid()) {
        cout << "\n資料正確！\n";
        dog.display();
