#include <iostream>
#include "pet.h"
using namespace std;

Pet::Pet(string n, int a) {
    name = n;
    age = a;
    cout << "寵物 " << name << " 已建立！" << endl;
}

void Pet::showInfo() {
    cout << "姓名: " << name << ", 年齡: " << age << endl;
}

Pet::~Pet() {
    cout << "和寵物 " << name << " 說再見！" << endl;
}
